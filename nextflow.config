manifest {
    name            = 'rnaseq-test'
    version         = '1.0.0'
    nextflowVersion = '>=23.04.0'
}

params {
    publish_dir_mode = 'copy'
    save_trimmed     = true
    max_memory       = '48.GB'
    max_cpus         = 6
    max_time         = '24.h'
}

process {
    withName: 'FASTQC.*'        { container = 'quay.io/biocontainers/fastqc:0.12.1--hdfd78af_0'      }
    withName: 'TRIMGALORE'      { container = 'quay.io/biocontainers/trim-galore:0.6.10--hdfd78af_0'  }
    withName: 'STAR_ALIGN'      { container = 'quay.io/biocontainers/star:2.7.11b--h43eeafb_0'        }
    withName: 'SAMTOOLS.*'      { container = 'quay.io/biocontainers/samtools:1.19--h50ea8bc_0'       }
    withName: 'FEATURECOUNTS'   { container = 'quay.io/biocontainers/subread:2.0.1--hed695b0_0'       }
    withName: 'MERGE_COUNTS'    { container = 'rnaseq_deseq2:1.0'                                     }
    withName: 'DESEQ2_ANALYSIS' { container = 'rnaseq_deseq2:1.0'                                     }
    withName: 'MULTIQC'         { container = 'quay.io/biocontainers/multiqc:1.21--pyhdfd78af_0'      }

    errorStrategy = { task.exitStatus in [137,139,143,247] ? 'retry' : 'finish' }
    maxRetries    = 3
    cpus          = 4
    memory        = 8.GB
    time          = '4.h'

    withName: 'STAR_ALIGN' {
        cpus      = 6
        memory    = '40.GB'
        time      = '12.h'
        maxForks  = 1
    }
    withName: 'FEATURECOUNTS' {
        cpus      = 4
        memory    = { check_max(8.GB * task.attempt, 'memory') }
        maxForks  = 2
    }
    withName: 'DESEQ2_ANALYSIS' {
        memory    = { check_max(8.GB * task.attempt, 'memory') }
    }
}

profiles {
    docker {
        docker.enabled       = true
        docker.runOptions    = '-u $(id -u):$(id -g) --platform linux/amd64 --pull never'
        docker.userEmulation = true
        docker.pullPolicy    = 'never'
        singularity.enabled  = false
    }
}

timeline { enabled = true; file = "${params.outdir}/pipeline_info/timeline.html"; overwrite = true }
report   { enabled = true; file = "${params.outdir}/pipeline_info/report.html";   overwrite = true }
trace    { enabled = true; file = "${params.outdir}/pipeline_info/trace.txt";     overwrite = true
           fields  = 'task_id,name,status,exit,realtime,cpus,memory,%cpu,%mem,workdir' }
dag      { enabled = true; file = "${params.outdir}/pipeline_info/dag.html";      overwrite = true }

def check_max(obj, type) {
    if (type == 'memory') {
        try { return obj.compareTo(params.max_memory as nextflow.util.MemoryUnit) == 1
              ? params.max_memory as nextflow.util.MemoryUnit : obj
        } catch(e) { return obj }
    } else if (type == 'time') {
        try { return obj.compareTo(params.max_time as nextflow.util.Duration) == 1
              ? params.max_time as nextflow.util.Duration : obj
        } catch(e) { return obj }
    } else if (type == 'cpus') {
        try { return Math.min(obj, params.max_cpus as int) } catch(e) { return obj }
    }
}
